{
  "name": "multichain-wallet-cli",
  "version": "1.0.0",
  "description": "Generate deterministic HD wallet addresses and private keys for multiple blockchains from a single BIP-39 mnemonic and optional BIP-39 passphrase",
  "main": "index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "tsx --no-deprecation src/index.ts"
  },
  "keywords": ["solana", "evm", "ton", "tron", "sui", "aptos", "multichain", "wallet", "generator", "cli"],
  "author": "Justin Hartman <code@justhart.com>",
  "license": "MIT",
  "dependencies": {
    "@mysten/sui.js": "^0.54.1",
    "@scure/base": "^2.0.0",
    "@solana/web3.js": "^1.98.4",
    "aptos": "^1.22.1",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.16.0",
    "tonweb": "^0.0.66",
    "tronweb": "^6.2.2",
    "ts-node": "^10.9.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
